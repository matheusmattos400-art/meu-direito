# ============================================================
# Variáveis de ambiente — EXEMPLO (copie para .env e preencha)
# NUNCA commitar o arquivo .env real. (LGPD / segurança)
# ============================================================

# ---------- Banco de dados (Postgres / Supabase São Paulo) ----------
# Local (docker-compose): postgres em localhost
DATABASE_URL="postgresql://app:app@localhost:5432/app?schema=public"
# Em produção, usar a connection string do Supabase (região sa-east-1).
# DIRECT_URL é usada pelo Prisma Migrate quando há pgbouncer (Supabase).
DIRECT_URL="postgresql://app:app@localhost:5432/app?schema=public"

# ---------- Supabase ----------
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""          # somente no backend, nunca exposta ao client
SUPABASE_STORAGE_BUCKET="documents"
SUPABASE_JWT_SECRET=""                 # segredo p/ validar o JWT do Supabase Auth na API
ADMIN_EMAILS=""                        # e-mails (sep. por vírgula) promovidos a ADMIN no login

# ---------- IA (multi-provedor) ----------
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
AI_DEFAULT_PROVIDER="anthropic"        # anthropic | openai | google
AI_MOCK="true"                         # true = roda a triagem simulada (sem API key); false = IA real

# ---------- Integrações externas ----------
DATAJUD_API_KEY=""                     # API Pública do Datajud (CNJ)
RESEND_API_KEY=""                      # e-mail transacional
# Gateway de pagamento (avaliar Stripe e/ou gateway BR p/ PIX/boleto)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ---------- App ----------
NODE_ENV="development"
API_PORT="3333"
WEB_URL="http://localhost:3000"
API_URL="http://localhost:3333"

# ---------- Segurança ----------
JWT_SECRET=""                          # validação de tokens (se aplicável)
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"
