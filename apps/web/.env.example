# ============================================================
# Front (Next.js) — copie para apps/web/.env.local e preencha.
# Apenas variáveis NEXT_PUBLIC_* ficam acessíveis no navegador.
# ============================================================

# URL base da API (NestJS). Em dev, a API sobe em :3333 com prefixo /api.
NEXT_PUBLIC_API_URL="http://localhost:3333/api"

# Supabase (mesmo projeto usado pela API). Chave ANON é pública por design.
# Opcionais quando usando o atalho de desenvolvimento (/dev-login).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Habilita a tela /dev-login (atalho local sem Supabase). NUNCA em produção.
NEXT_PUBLIC_DEV_AUTH="true"
