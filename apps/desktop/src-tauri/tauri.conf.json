{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Meu Direito — Admin",
  "version": "0.1.0",
  "identifier": "br.meudireito.admin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3001/admin"
  },
  "app": {
    "windows": [
      {
        "title": "Meu Direito — Administração",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
